<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/micp/db" VERSION="2026032400" COMMENT="XMLDB file for mod_micp"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>
        <TABLE NAME="micp" COMMENT="Main table for MICP activity instances">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="intro" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="grade" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="10" SEQUENCE="false"/>
                <FIELD NAME="launchpath" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="index.html" SEQUENCE="false"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="coursefk" TYPE="foreign" FIELDS="course" REFTABLE="course" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="course" UNIQUE="false" FIELDS="course"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="micp_events" COMMENT="Append-only event log table for MICP">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="micpid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="eventtype" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="payload" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="clientts" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="micpfk" TYPE="foreign" FIELDS="micpid" REFTABLE="micp" REFFIELDS="id"/>
                <KEY NAME="userfk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="micpid-userid" UNIQUE="false" FIELDS="micpid, userid"/>
                <INDEX NAME="micpid-eventtype" UNIQUE="false" FIELDS="micpid, eventtype"/>
                <INDEX NAME="micpid-timecreated" UNIQUE="false" FIELDS="micpid, timecreated"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="micp_submissions" COMMENT="Latest submission snapshot per user and MICP activity">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="micpid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="rawjson" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="clientmeta" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="score" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="reviewstatus" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="not_required" SEQUENCE="false"/>
                <FIELD NAME="finalscore" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="reviewjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="reviewedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="reviewedat" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="micpfk" TYPE="foreign" FIELDS="micpid" REFTABLE="micp" REFFIELDS="id"/>
                <KEY NAME="userfk" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="reviewerfk" TYPE="foreign" FIELDS="reviewedby" REFTABLE="user" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="micpid-userid" UNIQUE="true" FIELDS="micpid, userid"/>
                <INDEX NAME="micpid" UNIQUE="false" FIELDS="micpid"/>
                <INDEX NAME="reviewstatus" UNIQUE="false" FIELDS="reviewstatus"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>
