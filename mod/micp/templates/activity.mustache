<section class="mod-micp-activity" data-region="mod-micp-activity">
    <h2>{{name}}</h2>
    {{{intro}}}
    <div class="mod-micp-activity__summary" data-region="mod-micp-result-summary">
        <h3 class="mod-micp-activity__summary-title">{{resultsummarytitle}}</h3>
        <p class="mod-micp-activity__summary-row"><strong>{{submissionstatuslabel}}:</strong> <span data-field="status">{{resultsummary.statuslabel}}</span></p>
        <p class="mod-micp-activity__summary-row"><strong>{{activityscorelabel}}:</strong> <span data-field="score">{{resultsummary.scorelabel}}</span>%</p>
        <p class="mod-micp-activity__summary-row"><strong>{{gradelabel}}:</strong> <span data-field="rawgrade">{{resultsummary.rawgradelabel}}</span> / <span data-field="grademax">{{resultsummary.grademaxlabel}}</span></p>
        <p class="mod-micp-activity__summary-row"><strong>{{interactionstatelabel}}:</strong> <span data-field="interactions">{{resultsummary.interactionslabel}}</span></p>
        {{#resultsummary.showsubmittedat}}
            <p class="mod-micp-activity__summary-row mod-micp-activity__summary-row--last" data-region="mod-micp-submitted-at"><strong>{{lastsubmissionlabel}}:</strong> <span data-field="submittedat">{{resultsummary.submittedatlabel}}</span></p>
        {{/resultsummary.showsubmittedat}}
        {{^resultsummary.showsubmittedat}}
            <p class="mod-micp-activity__summary-row mod-micp-activity__summary-row--last mod-micp-activity__region--hidden" data-region="mod-micp-submitted-at"><strong>{{lastsubmissionlabel}}:</strong> <span data-field="submittedat"></span></p>
        {{/resultsummary.showsubmittedat}}
        {{#resultsummary.showdetails}}
            <div class="mod-micp-activity__details" data-region="mod-micp-result-details">
                <strong>{{interactionbreakdownlabel}}:</strong>
                <ul class="mod-micp-activity__details-list" data-region="mod-micp-result-details-list">
                    {{#resultsummary.details}}
                        <li>{{label}} — {{scorelabel}}</li>
                    {{/resultsummary.details}}
                </ul>
            </div>
        {{/resultsummary.showdetails}}
        {{^resultsummary.showdetails}}
            <div class="mod-micp-activity__details mod-micp-activity__region--hidden" data-region="mod-micp-result-details">
                <strong>{{interactionbreakdownlabel}}:</strong>
                <ul class="mod-micp-activity__details-list" data-region="mod-micp-result-details-list"></ul>
            </div>
        {{/resultsummary.showdetails}}
        {{#canviewreports}}
            <p class="mod-micp-activity__summary-link"><a href="{{reporturl}}">{{viewresultslabel}}</a></p>
        {{/canviewreports}}
    </div>
    <div class="mod-micp-activity__display">
        <div class="mod-micp-activity__toolbar" data-region="mod-micp-toolbar">
            <button
                type="button"
                class="btn btn-secondary mod-micp-activity__button"
                data-action="toggle-maximized"
                data-label-maximize="{{maximizeiframelabel}}"
                data-label-restore="{{restoreinlinelabel}}"
                aria-controls="{{iframeid}}"
                aria-pressed="false"
            >{{maximizeiframelabel}}</button>
        </div>
        <div class="mod-micp-activity__frame-shell" data-region="mod-micp-frame-shell">
            <div class="mod-micp-activity__frame" data-region="mod-micp-iframe-container">
                <iframe
                    id="{{iframeid}}"
                    class="mod-micp-activity__iframe"
                    src="{{iframesrc}}"
                    title="{{iframetitle}}"
                    loading="eager"
                    referrerpolicy="same-origin"
                    allowfullscreen="allowfullscreen"
                    data-region="mod-micp-iframe"
                    data-launch-path="{{launchpath}}"
                ></iframe>
            </div>
        </div>
    </div>
</section>
